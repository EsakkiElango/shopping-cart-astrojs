{
  "name": "shopping-cart",
  "version": "1.0.0",
  "description": "A DDD-structured shopping cart application built with Astro.js and TypeScript",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "start": "node ./dist/server/entry.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/node": "^9.2.2",
    "astro": "^5.8.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
