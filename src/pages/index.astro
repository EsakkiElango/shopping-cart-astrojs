---
import Layout from '../layouts/Layout.astro';

export const prerender = false;
---

<Layout title="Shopping — Cart">
  <header class="site-header">
    <div class="shell header-row">
      <div class="brand">
        <span class="brand-mark" aria-hidden="true">SC</span>
        <div>
          <p class="brand-name">Shopping — Cart</p>
          <p class="brand-sub">E-commerce shopping cart</p>
        </div>
      </div>
      <div class="header-actions">
        <a class="admin-link" href="/admin/products">Manage products</a>
        <p class="cart-badge" aria-live="polite">
          Cart · <span id="cart-count">0</span> item<span id="cart-count-plural">s</span>
        </p>
      </div>
    </div>
  </header>

  <main class="shell layout">
    <section class="catalog" aria-labelledby="catalog-heading">
      <h1 id="catalog-heading">The shelf</h1>
      <div id="product-grid" class="product-grid">
        <p class="muted">Loading products…</p>
      </div>
    </section>

    <aside class="cart-panel" aria-labelledby="cart-heading">
      <h2 id="cart-heading">Your cart</h2>
      <div id="cart-alert" class="alert" role="alert" hidden></div>
      <div id="cart-items" class="cart-items">
        <p class="muted">Loading cart…</p>
      </div>
      <dl class="cart-total">
        <dt>Total</dt>
        <dd id="cart-total">₹0.00</dd>
      </dl>
      <button class="checkout" id="checkout" disabled>Checkout</button>
    </aside>
  </main>
</Layout>

<script>
  interface MoneyDTO {
    cents: number;
    currency: string;
    formatted: string;
  }
  interface ProductDTO {
    id: string;
    name: string;
    description: string;
    price: MoneyDTO;
    stock: number;
  }
  interface CartItemDTO {
    productId: string;
    productName: string;
    unitPrice: MoneyDTO;
    quantity: number;
    subtotal: MoneyDTO;
  }
  interface CartDTO {
    items: CartItemDTO[];
    itemCount: number;
    total: MoneyDTO;
  }

  const grid = document.getElementById('product-grid')!;
  const cartItemsEl = document.getElementById('cart-items')!;
  const cartTotalEl = document.getElementById('cart-total')!;
  const cartCountEl = document.getElementById('cart-count')!;
  const cartCountPluralEl = document.getElementById('cart-count-plural')!;
  const alertEl = document.getElementById('cart-alert')!;

  let alertTimer: ReturnType<typeof setTimeout> | undefined;

  function showAlert(message: string): void {
    alertEl.textContent = message;
    alertEl.hidden = false;
    clearTimeout(alertTimer);
    alertTimer = setTimeout(() => {
      alertEl.hidden = true;
    }, 4500);
  }

  async function api<T>(path: string, init?: RequestInit): Promise<T> {
    const response = await fetch(path, {
      headers: init?.body ? { 'Content-Type': 'application/json' } : undefined,
      ...init,
    });
    const body = await response.json();
    if (!response.ok) {
      throw new Error(body?.error?.message ?? 'Something went wrong. Try again.');
    }
    return body as T;
  }

  function renderProducts(products: ProductDTO[]): void {
    if (products.length === 0) {
      grid.innerHTML = '<p class="muted">No products yet. Add some through the products API.</p>';
      return;
    }
    grid.replaceChildren(
      ...products.map((product) => {
        const card = document.createElement('article');
        card.className = 'product-card';
        const out = product.stock === 0;
        card.innerHTML = `
          <div class="product-top">
            <h3>${escapeHtml(product.name)}</h3>
            <p class="price">${product.price.formatted}</p>
          </div>
          <p class="description">${escapeHtml(product.description)}</p>
          <div class="product-actions">
            <span class="stock ${out ? 'stock-out' : ''}">${out ? 'Out of stock' : `${product.stock} in stock`}</span>
            <button class="add" data-id="${product.id}" ${out ? 'disabled' : ''}>Add to cart</button>
          </div>`;
        card.querySelector<HTMLButtonElement>('.add')?.addEventListener('click', () => addToCart(product.id));
        return card;
      }),
    );
  }

  function renderCart(cart: CartDTO): void {
    cartCountEl.textContent = String(cart.itemCount);
    cartCountPluralEl.textContent = cart.itemCount === 1 ? '' : 's';
    cartTotalEl.textContent = cart.total.formatted;

    if (cart.items.length === 0) {
      cartItemsEl.innerHTML = '<p class="muted">Your cart is empty. Add something from the shelf.</p>';
      return;
    }

    cartItemsEl.replaceChildren(
      ...cart.items.map((item) => {
        const row = document.createElement('div');
        row.className = 'cart-row';
        row.innerHTML = `
          <div class="cart-row-info">
            <p class="cart-row-name">${escapeHtml(item.productName)}</p>
            <p class="cart-row-price">${item.unitPrice.formatted} each</p>
          </div>
          <div class="cart-row-controls">
            <div class="stepper" role="group" aria-label="Quantity for ${escapeHtml(item.productName)}">
              <button class="step" data-action="decrement" aria-label="Decrease quantity">−</button>
              <span class="qty" aria-live="polite">${item.quantity}</span>
              <button class="step" data-action="increment" aria-label="Increase quantity">+</button>
            </div>
            <p class="subtotal">${item.subtotal.formatted}</p>
            <button class="remove" aria-label="Remove ${escapeHtml(item.productName)} from cart">Remove</button>
          </div>`;
        row
          .querySelector('[data-action="decrement"]')!
          .addEventListener('click', () => changeQuantity(item.productId, item.quantity - 1));
        row
          .querySelector('[data-action="increment"]')!
          .addEventListener('click', () => changeQuantity(item.productId, item.quantity + 1));
        row.querySelector('.remove')!.addEventListener('click', () => removeFromCart(item.productId));
        return row;
      }),
    );
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  async function addToCart(productId: string): Promise<void> {
    try {
      renderCart(await api<CartDTO>('/api/cart/items', {
        method: 'POST',
        body: JSON.stringify({ productId, quantity: 1 }),
      }));
    } catch (error) {
      showAlert((error as Error).message);
    }
  }

  async function changeQuantity(productId: string, quantity: number): Promise<void> {
    try {
      if (quantity < 1) {
        await removeFromCart(productId);
        return;
      }
      renderCart(await api<CartDTO>(`/api/cart/items/${productId}`, {
        method: 'PATCH',
        body: JSON.stringify({ quantity }),
      }));
    } catch (error) {
      showAlert((error as Error).message);
    }
  }

  async function removeFromCart(productId: string): Promise<void> {
    try {
      renderCart(await api<CartDTO>(`/api/cart/items/${productId}`, { method: 'DELETE' }));
    } catch (error) {
      showAlert((error as Error).message);
    }
  }

  async function load(): Promise<void> {
    try {
      const [products, cart] = await Promise.all([
        api<ProductDTO[]>('/api/products'),
        api<CartDTO>('/api/cart'),
      ]);
      renderProducts(products);
      renderCart(cart);
    } catch (error) {
      showAlert((error as Error).message);
    }
  }

  load();
</script>

<style>
  .shell {
    max-width: 68rem;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .site-header {
    background: var(--pine-deep);
    color: var(--card);
    border-bottom: 4px solid var(--ochre);
  }

  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    padding-bottom: 1rem;
    gap: 1rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border: 1.5px solid var(--ochre);
    border-radius: 50%;
    font-family: var(--font-display);
    letter-spacing: 0.05em;
  }

  .brand-name {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: 0.01em;
  }

  .brand-sub {
    margin: 0;
    font-size: 0.78rem;
    color: #cdd8cb;
  }

  .cart-badge {
    margin: 0;
    font-size: 0.9rem;
    border: 1px solid rgba(255 255 255 / 0.35);
    border-radius: 999px;
    padding: 0.35rem 0.9rem;
    white-space: nowrap;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .admin-link {
    color: var(--card);
    font-size: 0.85rem;
    text-decoration: underline;
    white-space: nowrap;
  }

  @media (max-width: 480px) {
    .header-actions {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }

  .layout {
    display: grid;
    grid-template-columns: 1fr 22rem;
    gap: 2rem;
    padding-top: 2.25rem;
    padding-bottom: 3rem;
    align-items: start;
  }

  h1 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 2rem;
    margin: 0 0 0.25rem;
  }

  .lede {
    color: var(--ink-soft);
    margin: 0 0 1.5rem;
    max-width: 34rem;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: 1rem;
  }

  .product-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .product-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
  }

  .product-card h3 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.05rem;
  }

  .price {
    margin: 0;
    font-variant-numeric: tabular-nums;
    color: var(--pine);
    font-weight: 600;
    white-space: nowrap;
  }

  .description {
    margin: 0;
    font-size: 0.86rem;
    color: var(--ink-soft);
    flex: 1;
  }

  .product-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }

  .stock {
    font-size: 0.78rem;
    color: var(--ink-soft);
  }

  .stock-out {
    color: var(--danger);
  }

  .add {
    background: var(--pine);
    color: var(--card);
    border: none;
    border-radius: 999px;
    padding: 0.45rem 0.95rem;
    font-size: 0.85rem;
    transition: background 120ms ease;
  }

  .add:hover:not(:disabled) {
    background: var(--pine-deep);
  }

  .add:disabled {
    background: var(--line);
    color: var(--ink-soft);
    cursor: not-allowed;
  }

  .cart-panel {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.25rem;
    position: sticky;
    top: 1rem;
  }

  .cart-panel h2 {
    font-family: var(--font-display);
    font-weight: 500;
    margin: 0 0 0.75rem;
    font-size: 1.3rem;
  }

  .alert {
    background: #f6e7e3;
    color: var(--danger);
    border: 1px solid #e4c4bc;
    border-radius: 8px;
    padding: 0.6rem 0.8rem;
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }

  .cart-items {
    display: flex;
    flex-direction: column;
  }

  .cart-row {
    padding: 0.75rem 0;
    border-bottom: 1px dashed var(--line);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cart-row-info {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .cart-row-name {
    margin: 0;
    font-weight: 600;
    font-size: 0.92rem;
  }

  .cart-row-price {
    margin: 0;
    font-size: 0.8rem;
    color: var(--ink-soft);
    white-space: nowrap;
  }

  .cart-row-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .stepper {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    overflow: hidden;
  }

  .step {
    background: none;
    border: none;
    width: 2rem;
    height: 1.9rem;
    line-height: 1;
    color: var(--pine);
    font-size: 1rem;
  }

  .step:hover {
    background: var(--paper);
  }

  .qty {
    min-width: 1.6rem;
    text-align: center;
    font-variant-numeric: tabular-nums;
    font-size: 0.9rem;
  }

  .subtotal {
    margin: 0;
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    font-size: 0.92rem;
  }

  .remove {
    background: none;
    border: none;
    color: var(--danger);
    font-size: 0.8rem;
    text-decoration: underline;
    padding: 0.2rem;
  }

  .cart-total {
    display: flex;
    justify-content: space-between;
    margin: 1rem 0;
    font-family: var(--font-display);
    font-size: 1.15rem;
  }

  .cart-total dd {
    margin: 0;
    font-variant-numeric: tabular-nums;
  }

  .checkout {
    width: 100%;
    background: var(--ochre);
    border: none;
    border-radius: 999px;
    color: #fff;
    padding: 0.65rem;
    font-size: 0.9rem;
  }

  .checkout:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .muted {
    color: var(--ink-soft);
    font-size: 0.9rem;
  }

  @media (max-width: 860px) {
    .layout {
      grid-template-columns: 1fr;
    }

    .cart-panel {
      position: static;
      order: -1;
    }
  }

  @media (max-width: 480px) {
    .header-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .product-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
